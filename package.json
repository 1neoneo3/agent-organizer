{
  "name": "agent-organizer",
  "version": "0.1.0",
  "description": "Multi-agent orchestration dashboard for Claude, Codex, and Gemini CLI task workflows.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1neoneo3/agent-organizer.git"
  },
  "bin": {
    "agent-organizer": "bin/agent-organizer.js"
  },
  "files": [
    "bin",
    "dist",
    "server",
    ".env.example",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "quickstart": "node ./bin/agent-organizer.js start",
    "doctor": "node ./bin/agent-organizer.js doctor",
    "dev": "concurrently -k \"tsx watch server/index.ts\" \"vite\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "lint": "tsc --noEmit",
    "build": "vite build && tsc -p tsconfig.node.json --noEmit",
    "start": "NODE_ENV=production tsx server/index.ts",
    "check": "tsc --noEmit",
    "test": "tsx --test 'src/**/*.test.ts' 'server/**/*.test.ts'",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepack": "npm run build"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "ioredis": "^5.10.0",
    "lucide-react": "^1.7.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tsx": "^4.19.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.5.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.3.0"
  }
}

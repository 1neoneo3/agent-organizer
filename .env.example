PORT=8791
SESSION_AUTH_TOKEN=change-me-to-random-secret
NODE_ENV=development
DB_PATH=data/agent-organizer.db

# Redis cache (set REDIS_ENABLED=false to disable)
REDIS_URL=redis://127.0.0.1:6379
REDIS_ENABLED=true

# Task lifecycle
AUTO_ASSIGN_TASK_ON_CREATE=true
AUTO_RUN_TASK_ON_CREATE=true
AUTO_DISPATCH_INTERVAL_MS=60000
# Max auto-respawns per orphaned in_progress task (resets on forward stage transitions, manual Run, feedback)
ORPHAN_AUTO_RESPAWN_MAX=3

# GitHub sync
GITHUB_SYNC_ENABLED=false
GITHUB_SYNC_REPO=
GITHUB_SYNC_TOKEN=
GITHUB_SYNC_PROJECT_PATH=
GITHUB_SYNC_INTERVAL_MS=300000

# Telegram
TELEGRAM_CONTROL_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
